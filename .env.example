CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Auth.js
AUTH_SECRET=                          # openssl rand -base64 32
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
ALLOW_NEW_SIGNUPS=false               # Set to true after migration to allow new user registration

# Session cookie names (defaults should work for most setups)
AUTH_SESSION_COOKIE_NAME=authjs.session-token
AUTH_SESSION_COOKIE_NAME_SECURE=__Secure-authjs.session-token
