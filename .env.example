CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Auth.js — also used by api-backend to validate the Origin header on /api/ws/* handshakes
AUTH_URL=http://localhost:3000        # Public URL for OAuth callbacks + WS Origin allowlist
AUTH_SECRET=                          # openssl rand -base64 32
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Pulsoid OAuth
PULSOID_CLIENT_ID=
PULSOID_CLIENT_SECRET=
PULSOID_REDIRECT_URI=              # e.g. https://yourdomain.com/api/oauth/pulsoid/callback
TOKEN_ENCRYPTION_KEY=              # openssl rand -base64 32
